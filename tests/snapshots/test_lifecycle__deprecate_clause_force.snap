---
source: tests/test_lifecycle.rs
expression: "normalize_output(&output, temp_dir.path(), &date)"
---
$ govctl rfc new Deprecate Clause RFC
Created RFC: gov/rfc/RFC-0001/rfc.json
  Clauses dir: gov/rfc/RFC-0001/clauses
exit: 0

$ govctl clause new RFC-0001:C-ONE Clause One -s Specification -k normative
Created clause: gov/rfc/RFC-0001/clauses/C-ONE.json
  Added to section 'Specification', path: clauses/C-ONE.json
exit: 0

$ govctl clause deprecate RFC-0001:C-ONE --force
Deprecated clause: RFC-0001:C-ONE
exit: 0

$ govctl clause list
┌────────┬──────────┬───────────┬────────────┬────────────┐
│ Clause ┆ RFC      ┆ Kind      ┆ Status     ┆ Title      │
╞════════╪══════════╪═══════════╪════════════╪════════════╡
│ C-ONE  ┆ RFC-0001 ┆ normative ┆ deprecated ┆ Clause One │
└────────┴──────────┴───────────┴────────────┴────────────┘
exit: 0
