---
source: tests/test_edit.rs
expression: "normalize_output(&output, temp_dir.path(), &date)"
---
$ govctl adr new Set Test
Created ADR: gov/adr/ADR-XXXX-set-test.toml
exit: 0

$ govctl adr add ADR-0001 alternatives Option A --pro Fast --con Fragile
Added 'Option A' to ADR-0001.alternatives
exit: 0

$ govctl adr set ADR-0001 alt[0].text Option A Revised
Set ADR-0001.alternatives[0].text = Option A Revised
exit: 0

$ govctl adr get ADR-0001 alt[0].text
Option A Revised
exit: 0

$ govctl adr set ADR-0001 alt[0].pros[0] Very fast
Set ADR-0001.alternatives[0].pros[0] = Very fast
exit: 0

$ govctl adr get ADR-0001 alt[0].pros[0]
Very fast
exit: 0

$ govctl adr set ADR-0001 alt[0].rejection_reason Superseded by Option B
Set ADR-0001.alternatives[0].rejection_reason = Superseded by Option B
exit: 0

$ govctl adr get ADR-0001 alt[0].rejection_reason
Superseded by Option B
exit: 0
