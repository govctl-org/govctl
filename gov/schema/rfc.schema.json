{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RFC Specification",
  "description": "JSON Schema for RFC source files",
  "type": "object",
  "required": [
    "rfc_id",
    "title",
    "version",
    "status",
    "phase",
    "owners",
    "created",
    "sections"
  ],
  "properties": {
    "rfc_id": {
      "type": "string",
      "pattern": "^RFC-\\d{4}$",
      "description": "Unique RFC identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable title"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "normative", "deprecated"],
      "description": "RFC lifecycle status"
    },
    "phase": {
      "type": "string",
      "enum": ["spec", "impl", "test", "stable"],
      "description": "RFC work phase"
    },
    "owners": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "List of responsible parties"
    },
    "created": {
      "type": "string",
      "format": "date",
      "description": "Creation date (YYYY-MM-DD)"
    },
    "updated": {
      "type": "string",
      "format": "date",
      "description": "Last update date (YYYY-MM-DD)"
    },
    "supersedes": {
      "type": "string",
      "pattern": "^RFC-\\d{4}$",
      "description": "RFC ID this replaces"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "clauses": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      },
      "description": "RFC sections with clause references"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(RFC-\\d{4}(?::C-[A-Z][A-Z0-9-]*)?|ADR-\\d{4}|WI-\\d{4}-\\d{2}-\\d{2}-(?:[a-f0-9]{4}(?:-\\d{3})?|\\d{3}))$"
      }
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date"],
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "date": { "type": "string", "format": "date" },
          "notes": { "type": "string" },
          "added": { "type": "array", "items": { "type": "string" } },
          "changed": { "type": "array", "items": { "type": "string" } },
          "deprecated": { "type": "array", "items": { "type": "string" } },
          "removed": { "type": "array", "items": { "type": "string" } },
          "fixed": { "type": "array", "items": { "type": "string" } },
          "security": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      },
      "description": "Version history"
    },
    "signature": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": false
}
